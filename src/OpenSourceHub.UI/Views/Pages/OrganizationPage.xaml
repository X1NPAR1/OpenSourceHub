<Page x:Class="OpenSourceHub.UI.Views.Pages.OrganizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Organizations">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization Org.Title}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Explore GitHub organizations, their members and repositories"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="44" FontSize="13" Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SearchCommand}" Height="44" Padding="20,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <controls:LoadingSpinnerControl Width="16" Height="16" Margin="0,0,8,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="&#xF136;" FontFamily="{StaticResource IconFont}" FontSize="14"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                            <TextBlock Text="{loc:Localization Org.Search}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Loading -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,100">
                    <controls:LoadingSpinnerControl Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Loading organization..." Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding Organization, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"
                            HorizontalAlignment="Center" Margin="0,80">
                    <TextBlock Text="&#xF136;" FontFamily="{StaticResource IconFont}"
                               FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                    <TextBlock Text="Search for an organization" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Enter an organization name like microsoft, google, or facebook"
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"
                               FontSize="13" TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center"/>
                </StackPanel>

                <!-- Results -->
                <StackPanel Visibility="{Binding Organization, Converter={StaticResource NullToVisibilityConverter}}">

                    <!-- Org header card -->
                    <Border Margin="0,0,0,24" CornerRadius="{StaticResource RadiusLG}"
                            BorderThickness="1" Padding="28,22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1829" Offset="0"/>
                                <GradientStop Color="#0A0A14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1A3A6B" Offset="0"/>
                                <GradientStop Color="#1A1A38" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.3" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Organization.Name}" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                                    <Border Background="#0A1400" CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                                            Visibility="{Binding Organization.IsVerified, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE930;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="11" Foreground="#10B981" Margin="0,0,5,0"/>
                                            <TextBlock Text="Verified" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#34D399"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Organization.Description}"
                                           FontSize="13" Foreground="{StaticResource SubTextBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,14"
                                           Visibility="{Binding Organization.Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74C;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="13">
                                                <Run Text="{Binding Organization.PublicRepos}" FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextBrush}"/>
                                                <Run Text=" repos" Foreground="{StaticResource MutedTextBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xF25A;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="13">
                                                <Run Text="{Binding Members.Count}" FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextBrush}"/>
                                                <Run Text=" members" Foreground="{StaticResource MutedTextBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Organization.Login}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Members + Repos grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Members -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MEMBERS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Members}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Padding="14,12" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:AvatarControl Width="34" Height="34"
                                                    ImageUrl="{Binding AvatarUrl}"
                                                    DisplayName="{Binding Login}"
                                                    Margin="0,0,12,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Login}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}">
                                                        <Run Text="{Binding Contributions}" FontWeight="SemiBold"/>
                                                        <Run Text=" contributions"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Repositories -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="REPOSITORIES" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Repositories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Padding="14,12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{StaticResource BrandPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0"
                                                               Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Language}" FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"
                                                               Visibility="{Binding Language, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="11" Foreground="#FCD34D" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding StargazersCount, Converter={StaticResource NumberToKiloConverter}}"
                                                                   FontSize="12" FontWeight="SemiBold" Foreground="#FCD34D"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
