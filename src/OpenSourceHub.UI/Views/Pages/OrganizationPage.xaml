<Page x:Class="OpenSourceHub.UI.Views.Pages.OrganizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Organizations">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="32,20">
                <TextBlock Text="{loc:Localization Org.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" FontSize="13" Margin="0,0,8,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="🏢  Search" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SearchCommand}" Height="42" MinWidth="120"/>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,60">
                    <TextBlock Text="{loc:Localization Org.Loading}" Style="{StaticResource CaptionStyle}" FontSize="14"/>
                </StackPanel>

                <StackPanel Visibility="{Binding Organization, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Organization.Name}" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <Border Margin="12,4,0,0" CornerRadius="4" Padding="8,2"
                                            Visibility="{Binding Organization.IsVerified, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Background><SolidColorBrush Color="#0078D4"/></Border.Background>
                                        <TextBlock Text="✓ Verified" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Organization.Description}" Style="{StaticResource CaptionStyle}"
                                           Margin="0,0,0,12"
                                           Visibility="{Binding Organization.Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Organization.PublicRepos}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="repos" FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="0,0,24,0"/>
                                    <TextBlock Text="{Binding Members.Count}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="{loc:Localization Org.Members}" FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Organization.Login}" FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Top Repos -->
                    <TextBlock Text="{loc:Localization Org.Repositories}" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding Repositories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionStyle}"
                                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                            <TextBlock Text="⭐" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding StargazersCount, Converter={StaticResource NumberToKiloConverter}}"
                                                       FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Language}" FontSize="11"
                                                   Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   Visibility="{Binding Language, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
