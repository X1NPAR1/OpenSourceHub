<Page x:Class="OpenSourceHub.UI.Views.Pages.TrendingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Trending">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="32,20">
                <TextBlock Text="{loc:Localization Trending.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Period Selector -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="{loc:Localization Trending.Today}" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="Daily" Margin="0,0,8,0"/>
                        <Button Content="{loc:Localization Trending.ThisWeek}" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="Weekly" Margin="0,0,8,0"/>
                        <Button Content="{loc:Localization Trending.ThisMonth}" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SelectPeriodCommand}" CommandParameter="Monthly"/>
                    </StackPanel>
                    <!-- Language Filter -->
                    <ComboBox Grid.Column="2" Style="{StaticResource ModernComboBoxStyle}"
                              ItemsSource="{Binding PopularLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Width="160" Height="36"/>
                    <Button Grid.Column="4" Content="↻ Refresh" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LoadCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,60">
                    <TextBlock Text="{loc:Localization Trending.Loading}" Style="{StaticResource CaptionStyle}" FontSize="14"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding TrendingRepositories}"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandPrimaryBrush}" Cursor="Hand"/>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionStyle}"
                                                   Margin="0,6,0,8" TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <WrapPanel>
                                            <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                                    Background="{StaticResource SurfaceBrush}"
                                                    Visibility="{Binding Language, Converter={StaticResource NullToVisibilityConverter}}">
                                                <TextBlock Text="{Binding Language}" FontSize="11"
                                                           Foreground="{StaticResource BrandPrimaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding UpdatedAt, Converter={StaticResource DateToRelativeConverter}}"
                                                       FontSize="11" Foreground="{StaticResource SubTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="⭐" FontSize="13" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding StargazersCount, Converter={StaticResource NumberToKiloConverter}}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#FFD700"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🍴" FontSize="13" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ForksCount, Converter={StaticResource NumberToKiloConverter}}"
                                                       FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
