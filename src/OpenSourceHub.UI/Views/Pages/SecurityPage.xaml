<Page x:Class="OpenSourceHub.UI.Views.Pages.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Security">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization Security.Title}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Assess security posture and identify risks"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="44" FontSize="13" Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AnalyzeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AnalyzeCommand}" Height="44" Padding="20,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <controls:LoadingSpinnerControl Width="16" Height="16" Margin="0,0,8,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="14"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                            <TextBlock Text="{loc:Localization Security.Scan}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Loading -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,100">
                    <controls:LoadingSpinnerControl Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Scanning repository security..." Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"
                            HorizontalAlignment="Center" Margin="0,80">
                    <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}"
                               FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                    <TextBlock Text="Enter a repository to scan" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Security analysis checks for maintenance issues, license compliance, and risk factors"
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"
                               FontSize="13" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"/>
                </StackPanel>

                <!-- Results -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}">

                    <!-- Severity summary cards -->
                    <TextBlock Text="RISK SUMMARY" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Critical -->
                        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="16,14" BorderThickness="1" BorderBrush="#4D0000" Background="#1C0000">
                            <StackPanel>
                                <TextBlock Text="CRITICAL" FontSize="9" FontWeight="Bold" Foreground="#FCA5A5" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding CriticalCount}" FontSize="30" FontWeight="Bold" Foreground="#EF4444"/>
                                <TextBlock Text="alerts" FontSize="10" Foreground="#7F1D1D" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- High -->
                        <Border Grid.Column="1" Margin="4,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="16,14" BorderThickness="1" BorderBrush="#4D1D00" Background="#1A0A00">
                            <StackPanel>
                                <TextBlock Text="HIGH" FontSize="9" FontWeight="Bold" Foreground="#FCA5A5" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HighCount}" FontSize="30" FontWeight="Bold" Foreground="#F97316"/>
                                <TextBlock Text="alerts" FontSize="10" Foreground="#7C2D12" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Medium -->
                        <Border Grid.Column="2" Margin="4,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="16,14" BorderThickness="1" BorderBrush="#3A2D00" Background="#150F00">
                            <StackPanel>
                                <TextBlock Text="MEDIUM" FontSize="9" FontWeight="Bold" Foreground="#FDE68A" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding MediumCount}" FontSize="30" FontWeight="Bold" Foreground="#F59E0B"/>
                                <TextBlock Text="alerts" FontSize="10" Foreground="#78350F" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Low -->
                        <Border Grid.Column="3" Margin="4,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="16,14" BorderThickness="1" BorderBrush="#0A2A1A" Background="#040F0A">
                            <StackPanel>
                                <TextBlock Text="LOW" FontSize="9" FontWeight="Bold" Foreground="#A7F3D0" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding LowCount}" FontSize="30" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock Text="alerts" FontSize="10" Foreground="#064E3B" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Security Score -->
                        <Border Grid.Column="4" Margin="8,0,0,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="16,14" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                Background="{StaticResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="SECURITY SCORE" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Analysis.SecurityScore, StringFormat='{}{0:F0}'}"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                <ProgressBar Style="{StaticResource ScoreBarStyle}" Margin="0,8,0,0"
                                             Value="{Binding Analysis.SecurityScore}" Maximum="100"
                                             Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Alert list -->
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="FINDINGS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,0"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding GenerateAiReportCommand}" Padding="14,8"
                                IsEnabled="{Binding IsGeneratingReport, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <controls:LoadingSpinnerControl Width="14" Height="14" Margin="0,0,7,0"
                                    Visibility="{Binding IsGeneratingReport, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}" FontSize="12"
                                           Margin="0,0,7,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsGeneratingReport, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                                <TextBlock Text="AI Risk Report" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Empty alerts state -->
                    <Border CornerRadius="{StaticResource RadiusMD}" Padding="28,24" Margin="0,0,0,16"
                            Background="#040F0A" BorderThickness="1" BorderBrush="#0A2A1A"
                            Visibility="{Binding Alerts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                       FontSize="36" HorizontalAlignment="Center"
                                       Foreground="#10B981" Margin="0,0,0,12" Opacity="0.8"/>
                            <TextBlock Text="{loc:Localization Security.NoAlerts}" FontSize="16"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Foreground="#34D399"/>
                            <TextBlock Text="No security issues detected for this repository"
                                       FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AlertCardStyle}">
                                    <Grid>
                                        <!-- Left severity bar -->
                                        <Border Width="5" CornerRadius="4,0,0,4" HorizontalAlignment="Left"
                                                Background="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.6"
                                                    Color="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}, ConverterParameter=color}"/>
                                            </Border.Effect>
                                        </Border>

                                        <StackPanel Margin="18,16,16,16">
                                            <!-- Title row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}, ConverterParameter=color}"
                                                                          Opacity="0.2"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding RiskLevel}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}}"/>
                                                </Border>
                                                <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" Padding="8,3">
                                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                                               Foreground="{StaticResource SubTextBrush}"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                                            <Border Background="#0A1400" CornerRadius="{StaticResource RadiusSM}"
                                                    Padding="12,9"
                                                    Visibility="{Binding Recommendation, Converter={StaticResource NullToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                                               FontSize="12" Foreground="#34D399" Margin="0,0,8,0"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding Recommendation}" FontSize="12"
                                                               Foreground="#6EE7B7" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- AI Risk Report -->
                    <Border Style="{StaticResource CardStyle}" Padding="24,20" Margin="0,8,0,0"
                            Visibility="{Binding AiRiskReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                           FontSize="16" Foreground="#8B5CF6" Margin="0,0,10,0"/>
                                <TextBlock Text="AI Risk Report" Style="{StaticResource SubHeadingStyle}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding AiRiskReport}" FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
