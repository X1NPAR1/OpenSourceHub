<Page x:Class="OpenSourceHub.UI.Views.Pages.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Security">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="32,20">
                <TextBlock Text="{loc:Localization Security.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" FontSize="13" Margin="0,0,8,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AnalyzeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="🛡️  Analyze" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AnalyzeCommand}" Height="42" MinWidth="140"/>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,60">
                    <TextBlock Text="Running security analysis..." Style="{StaticResource CaptionStyle}" FontSize="14"/>
                </StackPanel>

                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}">

                    <!-- Summary Cards -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="🔴" FontSize="24" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding CriticalCount}" FontSize="28" FontWeight="Bold" Foreground="#A80000"/>
                                <TextBlock Text="Critical" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="🟠" FontSize="24" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HighCount}" FontSize="28" FontWeight="Bold" Foreground="#D83B01"/>
                                <TextBlock Text="High" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="🟡" FontSize="24" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding MediumCount}" FontSize="28" FontWeight="Bold" Foreground="#FFB900"/>
                                <TextBlock Text="Medium" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="🟢" FontSize="24" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding LowCount}" FontSize="28" FontWeight="Bold" Foreground="#107C10"/>
                                <TextBlock Text="Low" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Security Score -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                            Visibility="{Binding Analysis, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="{loc:Localization Repo.SecurityScore}" Style="{StaticResource SubHeadingStyle}" FontSize="15"/>
                                <TextBlock Text="{Binding Analysis.SecurityScore, StringFormat='{}{0:F1}/100'}"
                                           HorizontalAlignment="Right" FontSize="22" FontWeight="Bold"
                                           Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                            </Grid>
                            <ProgressBar Value="{Binding Analysis.SecurityScore}" Maximum="100"
                                         Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"
                                         Style="{StaticResource ScoreBarStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Alerts List -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="{loc:Localization Security.Alerts}" Style="{StaticResource SubHeadingStyle}" FontSize="15"/>
                                <Button Grid.Column="1" Content="🤖 AI Risk Report" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding GenerateAiReportCommand}" HorizontalAlignment="Right"
                                        IsEnabled="{Binding IsGeneratingReport, Converter={StaticResource InverseBoolConverter}}"
                                        FontSize="12" Padding="12,6"/>
                            </Grid>

                            <TextBlock Text="{loc:Localization Security.NoAlerts}" Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Center" Margin="0,24"
                                       Visibility="{Binding Alerts.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>

                            <ItemsControl ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Margin="0,0,0,8" Padding="16">
                                            <Border.Background>
                                                <SolidColorBrush Color="#2D2D42"/>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="8" CornerRadius="4" Margin="0,0,12,0"
                                                        Background="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}}"/>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <Border CornerRadius="4" Padding="8,2" Margin="0,0,8,0"
                                                                Background="{Binding RiskLevel, Converter={StaticResource SecurityRiskToColorConverter}}">
                                                            <TextBlock Text="{Binding RiskLevel}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <Border CornerRadius="4" Padding="8,2" Background="{StaticResource SurfaceBrush}">
                                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource BodyTextStyle}"
                                                               FontSize="12" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Visibility="{Binding Recommendation, Converter={StaticResource NullToVisibilityConverter}}">
                                                        <TextBlock Text="💡 " FontSize="12"/>
                                                        <TextBlock Text="{Binding Recommendation}" FontSize="12"
                                                                   Foreground="{StaticResource BrandPrimaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- AI Risk Report -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                            Visibility="{Binding AiRiskReport, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="🤖 AI Risk Report" Style="{StaticResource SubHeadingStyle}" FontSize="15" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding AiRiskReport}" Style="{StaticResource BodyTextStyle}" FontSize="13"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
