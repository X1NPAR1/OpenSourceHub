<Page x:Class="OpenSourceHub.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      xmlns:domain="clr-namespace:OpenSourceHub.Domain.Enums;assembly=OpenSourceHub.Domain"
      Background="{StaticResource BackgroundBrush}" Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">
            <TextBlock Text="{loc:Localization Settings.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,24"/>

            <!-- Appearance -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Settings.Appearance}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.Theme}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Right" Width="200" Style="{StaticResource ModernComboBoxStyle}"
                                  SelectedValue="{Binding SelectedTheme}" SelectedValuePath="Tag" Height="36">
                            <ComboBoxItem Content="{loc:Localization Settings.ThemeSystem}" Tag="{x:Static domain:AppTheme.System}"/>
                            <ComboBoxItem Content="{loc:Localization Settings.ThemeLight}" Tag="{x:Static domain:AppTheme.Light}"/>
                            <ComboBoxItem Content="{loc:Localization Settings.ThemeDark}" Tag="{x:Static domain:AppTheme.Dark}"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.Language}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Right" Width="200" Style="{StaticResource ModernComboBoxStyle}"
                                  SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Tag" Height="36">
                            <ComboBoxItem Content="{loc:Localization Settings.LanguageEn}" Tag="{x:Static domain:AppLanguage.English}"/>
                            <ComboBoxItem Content="{loc:Localization Settings.LanguageTr}" Tag="{x:Static domain:AppLanguage.Turkish}"/>
                            <ComboBoxItem Content="{loc:Localization Settings.LanguageRu}" Tag="{x:Static domain:AppLanguage.Russian}"/>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <TextBlock Text="{loc:Localization Settings.EnableAnimations}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding EnableAnimations}"
                                  Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- AI Configuration -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Settings.AI}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.AiProvider}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Right" Width="200" Style="{StaticResource ModernComboBoxStyle}"
                                  SelectedValue="{Binding SelectedAiProvider}" SelectedValuePath="Tag" Height="36">
                            <ComboBoxItem Content="OpenAI" Tag="{x:Static domain:AiProvider.OpenAI}"/>
                            <ComboBoxItem Content="Ollama (Local)" Tag="{x:Static domain:AiProvider.Ollama}"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Localization Settings.OpenAiKey}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <PasswordBox x:Name="ApiKeyBox" Style="{StaticResource ModernPasswordBoxStyle}" Height="36"
                                 Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Localization Settings.OpenAiModel}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding OpenAiModel}"
                             Height="36" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Localization Settings.OllamaEndpoint}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding OllamaEndpoint}"
                             Height="36" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Localization Settings.OllamaModel}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding OllamaModel}" Height="36"/>
                </StackPanel>
            </Border>

            <!-- Cache & Performance -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Settings.Cache}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.EnableCaching}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding EnableCaching}"
                                  Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.CacheDuration}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <TextBox HorizontalAlignment="Right" Width="80" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding CacheDuration}" Height="36"/>
                    </Grid>

                    <Button Content="{loc:Localization Settings.ClearCache}" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearCacheCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Reports -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Report.Title}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,16"/>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Localization Settings.ReportsPath}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding ReportsOutputPath}" Height="36" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="{loc:Localization Report.Browse}"
                                Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseReportsPathCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Notifications & Privacy -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Settings.Privacy}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,16"/>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.EnableNotifications}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding EnableNotifications}"
                                  Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{loc:Localization Settings.EnableAutoUpdate}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding EnableAutoUpdate}"
                                  Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="{loc:Localization Settings.EnableTelemetry}" Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding EnableTelemetry}"
                                  Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="{loc:Localization Settings.Save}" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}" MinWidth="120" Margin="0,0,12,0"/>
                <Button Content="{loc:Localization Settings.Reset}" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ResetCommand}" MinWidth="120" Margin="0,0,12,0"/>
                <Button Content="{loc:Localization Settings.ExportLogs}" Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding ExportLogsCommand}"/>
            </StackPanel>

            <!-- About -->
            <Border Style="{StaticResource CardStyle}" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Settings.About}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Product" Style="{StaticResource CaptionStyle}"/>
                        <TextBlock Text="OpenSourceHub" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Version" Style="{StaticResource CaptionStyle}"/>
                        <TextBlock Text="1.1.5" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Publisher" Style="{StaticResource CaptionStyle}"/>
                        <TextBlock Text="XinPari Software" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="License" Style="{StaticResource CaptionStyle}"/>
                        <TextBlock Text="MIT" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
