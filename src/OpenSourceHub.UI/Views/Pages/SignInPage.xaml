<Page x:Class="OpenSourceHub.UI.Views.Pages.SignInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}"
      Title="Sign In">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Hero left panel -->
        <Border Grid.Column="0" Grid.ColumnSpan="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D1117" Offset="0"/>
                    <GradientStop Color="#161B22" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="OpenSourceHub" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="Analyze. Discover. Build Better." FontSize="16"
                           Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,32"/>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Repository Health Analysis" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="AI-Powered Insights" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Security Scanning" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✓" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Trend Discovery" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Foreground="{StaticResource BrandPrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Professional Reports" Foreground="{StaticResource TextBrush}" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Sign In Form -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center" Margin="48,60">

                    <!-- Logo -->
                    <Border Width="64" Height="64" CornerRadius="16"
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0078D4" Offset="0"/>
                                <GradientStop Color="#00BCF2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="OSH" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{loc:Localization Auth.SignIn}" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Connect your GitHub account to get started"
                               FontSize="13" Foreground="{StaticResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Token Input -->
                    <TextBlock Text="Personal Access Token" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,8"/>

                    <PasswordBox x:Name="TokenBox" Style="{StaticResource ModernPasswordBoxStyle}"
                                 FontSize="13" Height="42" Margin="0,0,0,4"/>

                    <TextBlock x:Name="TokenError" Text="{Binding TokenError}"
                               Foreground="{StaticResource ErrorBrush}" FontSize="12"
                               Margin="0,0,0,8"
                               Visibility="{Binding TokenError, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <!-- Authenticate Button -->
                    <Button Content="{loc:Localization Auth.SignInButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AuthenticateCommand}"
                            Height="42" FontSize="14" Margin="0,8,0,0"/>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Authenticating..." FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Style="{StaticResource DividerStyle}" Margin="0,24"/>

                    <!-- Help -->
                    <TextBlock Text="How to get a token:" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,16">
                        Go to GitHub Settings → Developer settings → Personal access tokens → Generate new token.
                        Required scopes: repo, read:org, read:user, user:email
                    </TextBlock>

                    <Button Content="Generate Token on GitHub →"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding OpenTokenPageCommand}"
                            HorizontalAlignment="Left" FontSize="12"
                            Foreground="{StaticResource BrandPrimaryBrush}"/>

                    <!-- Footer -->
                    <TextBlock Text="OpenSourceHub v1.1.5 · © 2026 XinPari Software"
                               FontSize="10" Foreground="{StaticResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,40,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#161B22" Offset="0"/>
                    <GradientStop Color="#0D1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
    </Grid>
</Page>
