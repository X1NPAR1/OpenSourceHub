<Page x:Class="OpenSourceHub.UI.Views.Pages.ComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Compare">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization Compare.Title}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Compare up to 4 repositories side-by-side"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding NewRepoQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="44" FontSize="13" Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddRepositoryCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddRepositoryCommand}" Height="44" Padding="18,0" Margin="0,0,8,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <controls:LoadingSpinnerControl Width="16" Height="16" Margin="0,0,8,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="14"
                                       Margin="0,0,7,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                            <TextBlock Text="{loc:Localization Compare.Add}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearAllCommand}" Height="44" Padding="14,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Localization Compare.Clear}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Added repos chips -->
                <StackPanel Visibility="{Binding Repositories.Count, Converter={StaticResource ListCountToVisibilityConverter}}"
                            Margin="0,0,0,20">
                    <TextBlock Text="COMPARING" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Repositories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="14,7" Margin="0,0,8,8"
                                        BorderThickness="1" BorderBrush="{StaticResource BrandPrimaryBrush}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#0D2E5A" Offset="0"/>
                                            <GradientStop Color="#0A3070" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" Margin="0,0,10,0"
                                                   VerticalAlignment="Center"/>
                                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveRepositoryCommand,
                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding FullName}">
                                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,80"
                            Visibility="{Binding Repositories.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <TextBlock Text="&#xE7A8;" FontFamily="{StaticResource IconFont}"
                               FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                    <TextBlock Text="Add repositories to compare" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Use format owner/repo — add up to 4 repositories"
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"
                               FontSize="13" TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center"/>
                </StackPanel>

                <!-- Comparison tables -->
                <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- Repository stats table -->
                    <TextBlock Text="REPOSITORY OVERVIEW" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,20">
                        <DataGrid ItemsSource="{Binding Repositories}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repository" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="⭐ Stars" Binding="{Binding StargazersCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="🍴 Forks" Binding="{Binding ForksCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="🐛 Issues" Binding="{Binding OpenIssuesCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="110"/>
                                <DataGridTextColumn Header="License" Binding="{Binding License}" Width="110"/>
                                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat='yyyy-MM-dd'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Health scores table -->
                    <TextBlock Text="HEALTH SCORES" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid ItemsSource="{Binding Analyses}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repository" Binding="{Binding RepositoryFullName}" Width="*"/>
                                <DataGridTextColumn Header="🏥 Health" Binding="{Binding HealthScore, StringFormat=F1}" Width="90"/>
                                <DataGridTextColumn Header="🔧 Maint." Binding="{Binding MaintenanceScore, StringFormat=F1}" Width="90"/>
                                <DataGridTextColumn Header="🛡️ Security" Binding="{Binding SecurityScore, StringFormat=F1}" Width="90"/>
                                <DataGridTextColumn Header="👥 Community" Binding="{Binding CommunityScore, StringFormat=F1}" Width="100"/>
                                <DataGridTextColumn Header="⚡ Activity" Binding="{Binding ActivityScore, StringFormat=F1}" Width="90"/>
                                <DataGridTextColumn Header="🌟 Popularity" Binding="{Binding PopularityScore, StringFormat=F1}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
