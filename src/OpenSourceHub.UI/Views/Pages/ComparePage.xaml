<Page x:Class="OpenSourceHub.UI.Views.Pages.ComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Compare">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="32,20">
                <TextBlock Text="{loc:Localization Compare.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding NewRepoQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="42" FontSize="13" Margin="0,0,8,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddRepositoryCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="{loc:Localization Compare.AddRepo}" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddRepositoryCommand}" Height="42" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="{loc:Localization Compare.Clear}" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearAllCommand}" Height="42"/>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,40">
                    <TextBlock Text="{loc:Localization Common.Loading}" Style="{StaticResource CaptionStyle}" FontSize="14"/>
                </StackPanel>

                <!-- Added repos chips -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                            Visibility="{Binding Repositories.Count, Converter={StaticResource ListCountToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Repositories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="12,6" Margin="0,0,8,0"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BrandPrimaryBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FullName}" FontSize="12"
                                                   Foreground="{StaticResource BrandPrimaryBrush}"/>
                                        <Button Content="×" Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding DataContext.RemoveRepositoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Width="20" Height="20" Padding="0"
                                                Foreground="{StaticResource SubTextBrush}" FontSize="14" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding Repositories.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,80">
                    <TextBlock Text="⚖️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Localization Compare.AddFirst}" Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock Text="Add 2-4 repositories to compare their metrics side by side."
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Comparison Table -->
                <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Comparison Results" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,16"/>

                    <Border Style="{StaticResource CardStyle}">
                        <DataGrid ItemsSource="{Binding Repositories}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repository" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="⭐ Stars" Binding="{Binding StargazersCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="🍴 Forks" Binding="{Binding ForksCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="🐛 Issues" Binding="{Binding OpenIssuesCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="120"/>
                                <DataGridTextColumn Header="License" Binding="{Binding License}" Width="120"/>
                                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat='yyyy-MM-dd'}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock Text="Health Score Comparison" Style="{StaticResource SubHeadingStyle}" Margin="0,24,0,16"/>
                    <Border Style="{StaticResource CardStyle}">
                        <DataGrid ItemsSource="{Binding Analyses}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repository" Binding="{Binding RepositoryFullName}" Width="*"/>
                                <DataGridTextColumn Header="🏥 Health" Binding="{Binding HealthScore, StringFormat=F1}" Width="100"/>
                                <DataGridTextColumn Header="🔧 Maintenance" Binding="{Binding MaintenanceScore, StringFormat=F1}" Width="120"/>
                                <DataGridTextColumn Header="🛡️ Security" Binding="{Binding SecurityScore, StringFormat=F1}" Width="100"/>
                                <DataGridTextColumn Header="👥 Community" Binding="{Binding CommunityScore, StringFormat=F1}" Width="120"/>
                                <DataGridTextColumn Header="⚡ Activity" Binding="{Binding ActivityScore, StringFormat=F1}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
