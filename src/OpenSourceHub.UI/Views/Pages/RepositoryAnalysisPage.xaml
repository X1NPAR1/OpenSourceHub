<Page x:Class="OpenSourceHub.UI.Views.Pages.RepositoryAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Repository Analysis">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER + SEARCH ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization Repo.Analyze}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Analyze repository health, security, and community metrics"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="44" FontSize="13" Margin="0,0,10,0"
                             x:Name="SearchBox">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AnalyzeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AnalyzeCommand}" Height="44" Padding="20,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <controls:LoadingSpinnerControl Width="16" Height="16" Margin="0,0,8,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="&#xF13E;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                            <TextBlock Text="{loc:Localization Repo.Analyze}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Error -->
                <Border Grid.Row="1" Padding="12,9" Margin="0,10,0,0" CornerRadius="{StaticResource RadiusSM}"
                        Background="#1C080A" BorderThickness="1" BorderBrush="{StaticResource ErrorBrush}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}"
                                   Foreground="{StaticResource ErrorBrush}" FontSize="13" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Loading -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,100">
                    <controls:LoadingSpinnerControl Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"
                            HorizontalAlignment="Center" Margin="0,80">
                    <TextBlock Text="&#xF13E;" FontFamily="{StaticResource IconFont}"
                               FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                    <TextBlock Text="Enter a repository to analyze"
                               FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Use format:  owner/repo  or paste a full GitHub URL"
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center" FontSize="13"/>
                    <Border HorizontalAlignment="Center" Margin="0,16,0,0"
                            Background="{StaticResource ElevatedBrush}" CornerRadius="6" Padding="16,8">
                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="12"
                                   Foreground="{StaticResource BrandAccentBrush}">
                            <Run Text="microsoft/vscode"/>
                            <Run Text="   ·   " Foreground="{StaticResource MutedTextBrush}"/>
                            <Run Text="torvalds/linux"/>
                            <Run Text="   ·   " Foreground="{StaticResource MutedTextBrush}"/>
                            <Run Text="vuejs/vue"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Results -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}">

                    <!-- ── Repo Header Card ── -->
                    <Border Margin="0,0,0,24" CornerRadius="{StaticResource RadiusLG}"
                            BorderThickness="1" Padding="26,22">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1A3A6B" Offset="0"/>
                                <GradientStop Color="#1A1A38" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1829" Offset="0"/>
                                <GradientStop Color="#0A0A14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <!-- Title row -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Repository.FullName}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,12,0"/>
                                    <Border Background="#4D1D00" CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                                            Visibility="{Binding Repository.IsArchived, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="ARCHIVED" FontSize="9" FontWeight="Bold" Foreground="#FCA5A5"/>
                                    </Border>
                                    <Border Background="#1A1035" CornerRadius="4" Padding="8,3"
                                            Visibility="{Binding Repository.IsPrivate, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="PRIVATE" FontSize="9" FontWeight="Bold" Foreground="#C4B5FD"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding Repository.Description}"
                                           FontSize="13" Foreground="{StaticResource SubTextBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,14"
                                           Visibility="{Binding Repository.Description, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Tags row -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Border Style="{StaticResource ChipStyle}"
                                            Visibility="{Binding Repository.Language, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Repository.Language}" FontSize="11"
                                                   Foreground="{StaticResource BrandAccentBrush}" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}"
                                            Visibility="{Binding Repository.License, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D4;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="10" Margin="0,0,5,0" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding Repository.License}" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock FontSize="11" Foreground="{StaticResource SubTextBrush}">
                                            <Run Text="&#xE923;" FontFamily="{StaticResource IconFont}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Repository.UpdatedAt, Converter={StaticResource DateToRelativeConverter}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- Stats row -->
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1A1400" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="#FCD34D" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Repository.StargazersCount, Converter={StaticResource NumberToKiloConverter}}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#FCD34D"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#0A1600" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8F2;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="#34D399" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Repository.ForksCount, Converter={StaticResource NumberToKiloConverter}}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#34D399"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#140A0A" CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Foreground="#FCA5A5" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Repository.OpenIssuesCount}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#FCA5A5"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ToggleFavoriteCommand}" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,7,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE734;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                            <Setter Property="Text" Value="&#xE735;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding IsFavorite, Converter={StaticResource FavoriteLabelConverter}}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding OpenOnGitHubCommand}" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71B;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Margin="0,0,7,0"/>
                                        <TextBlock Text="Open on GitHub" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding CopyCloneUrlCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Margin="0,0,7,0"/>
                                        <TextBlock Text="Copy Clone URL" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Health Scores 3×2 ── -->
                    <StackPanel Visibility="{Binding Analysis, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="HEALTH SCORES" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Health Score -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ScoreCardStyle}" Margin="0,0,8,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE751;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#10B981" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Health}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.HealthScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.HealthScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.HealthScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.HealthScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.HealthScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Maintenance Score -->
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ScoreCardStyle}" Margin="4,0,4,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE90F;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#F59E0B" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Maintenance}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.MaintenanceScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.MaintenanceScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.MaintenanceScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.MaintenanceScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.MaintenanceScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Security Score -->
                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource ScoreCardStyle}" Margin="8,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#3B82F6" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Security}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.SecurityScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.SecurityScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.SecurityScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.SecurityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Community Score -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ScoreCardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xF136;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#8B5CF6" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Community}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.CommunityScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.CommunityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.CommunityScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.CommunityScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.CommunityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Popularity Score -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ScoreCardStyle}" Margin="4,0,4,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE734;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#F59E0B" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Popularity}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.PopularityScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.PopularityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.PopularityScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.PopularityScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.PopularityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Activity Score -->
                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ScoreCardStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xEC4A;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#06B6D4" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Localization Score.Activity}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Analysis.ActivityScore, StringFormat='{}{0:F0}'}"
                                               FontSize="36" FontWeight="Bold" Margin="0,0,0,4"
                                               Foreground="{Binding Analysis.ActivityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                    <TextBlock Text="{Binding Analysis.ActivityScore, Converter={StaticResource ScoreToLevelConverter}}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10"/>
                                    <ProgressBar Style="{StaticResource ScoreBarStyle}"
                                                 Value="{Binding Analysis.ActivityScore}" Maximum="100"
                                                 Foreground="{Binding Analysis.ActivityScore, Converter={StaticResource HealthScoreToColorConverter}}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── Documentation + Metrics ── -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Documentation checklist -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DOCUMENTATION" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasReadme, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="README.md" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasContributing, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="CONTRIBUTING.md" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasLicense, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="LICENSE" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasCodeOfConduct, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="CODE_OF_CONDUCT.md" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasSecurityPolicy, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="SECURITY.md" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasIssueTemplates, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Issue Templates" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Analysis.HasPrTemplates, Converter={StaticResource BoolCheckConverter}}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="PR Templates" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Activity metrics -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ACTIVITY METRICS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Commits / month" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.CommitFrequencyPerMonth}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Active contributors" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.ActiveContributors}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Total contributors" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.TotalContributors}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Days since last commit" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.DaysSinceLastCommit}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Issue close ratio" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.IssueCloseRatio, StringFormat=P0}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="PR merge ratio" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.PrMergeRatio, StringFormat=P0}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DocCheckStyle}">
                                    <Grid>
                                        <TextBlock Text="Total releases" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding Analysis.TotalReleases}"
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── Recommendations + Warnings ── -->
                        <Grid Margin="0,0,0,24"
                              Visibility="{Binding Analysis.Recommendations.Count, Converter={StaticResource ListCountToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RECOMMENDATIONS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding Analysis.Recommendations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="{StaticResource RadiusSM}" Padding="14,11"
                                                    Margin="0,0,0,8" BorderThickness="1" BorderBrush="#1A3A1A"
                                                    Background="#0A160A">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                                               FontSize="12" Foreground="#34D399" Margin="0,0,10,0"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding}" FontSize="12"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="WARNINGS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding Analysis.Warnings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="{StaticResource RadiusSM}" Padding="14,11"
                                                    Margin="0,0,0,8" BorderThickness="1" BorderBrush="#3A1A00"
                                                    Background="#1A0A00">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}"
                                                               FontSize="12" Foreground="#FCA5A5" Margin="0,0,10,0"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding}" FontSize="12"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- ── AI Summary ── -->
                        <Border Style="{StaticResource CardStyle}" Padding="24,20" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="#8B5CF6" Margin="0,0,10,0"/>
                                        <TextBlock Text="{loc:Localization AI.Summary}" Style="{StaticResource SubHeadingStyle}"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding GenerateAiSummaryCommand}" Padding="16,8"
                                            IsEnabled="{Binding IsGeneratingAi, Converter={StaticResource InverseBoolConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:LoadingSpinnerControl Width="14" Height="14" Margin="0,0,7,0"
                                                Visibility="{Binding IsGeneratingAi, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsGeneratingAi, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                                            <TextBlock Text="{loc:Localization AI.Generate}" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Placeholder -->
                                <TextBlock Text="{loc:Localization AI.Placeholder}"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"
                                           FontStyle="Italic"
                                           Visibility="{Binding AiSummary, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"/>

                                <!-- AI Result -->
                                <TextBlock Text="{Binding AiSummary}" FontSize="13"
                                           Foreground="{StaticResource SubTextBrush}"
                                           TextWrapping="Wrap" LineHeight="22"
                                           Visibility="{Binding AiSummary, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Q&A -->
                                <Separator Margin="0,16" Background="{StaticResource BorderSubtleBrush}"/>
                                <TextBlock Text="Ask AI about this repository" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                             Text="{Binding AiQuestion, UpdateSourceTrigger=PropertyChanged}"
                                             Height="40" FontSize="12" Margin="0,0,8,0">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding AskAiCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding AskAiCommand}" Height="40" Padding="16,0">
                                        <TextBlock Text="Ask →" FontSize="12"/>
                                    </Button>
                                </Grid>
                                <Border Margin="0,10,0,0" Background="{StaticResource ElevatedBrush}"
                                        CornerRadius="{StaticResource RadiusSM}" Padding="16,14"
                                        Visibility="{Binding AiAnswer, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding AiAnswer}" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}"
                                               TextWrapping="Wrap" LineHeight="20"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── Contributors ── -->
                        <StackPanel Visibility="{Binding Contributors.Count, Converter={StaticResource ListCountToVisibilityConverter}}">
                            <TextBlock Text="CONTRIBUTORS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Contributors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="{StaticResource RadiusSM}" Padding="12,9"
                                                Margin="0,0,8,8" BorderThickness="1"
                                                Background="{StaticResource CardBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:AvatarControl Width="28" Height="28"
                                                    ImageUrl="{Binding AvatarUrl}"
                                                    DisplayName="{Binding Login}"
                                                    Margin="0,0,8,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Login}" FontSize="12"
                                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                    <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}">
                                                        <Run Text="{Binding Contributions, Mode=OneWay}"/>
                                                        <Run Text=" commits"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

