<Page x:Class="OpenSourceHub.UI.Views.Pages.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Logs">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{loc:Localization Logs.Title}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Application event log — debug, info, warnings and errors"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding ExportCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEDE1;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                       Margin="0,0,7,0"/>
                            <TextBlock Text="{loc:Localization Logs.Export}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding ClearCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                       Margin="0,0,7,0"/>
                            <TextBlock Text="{loc:Localization Logs.Clear}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="36,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FILTER:" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>

                    <!-- Stat badges + filter buttons -->
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                            Command="{Binding FilterCommand}" CommandParameter="All" Height="32" Padding="14,0">
                        <TextBlock Text="All" FontSize="12"/>
                    </Button>

                    <Button Margin="0,0,6,0" Command="{Binding FilterCommand}" CommandParameter="Info"
                            Height="32" Padding="14,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLevel}" Value="Info">
                                        <Setter Property="Foreground" Value="#60A5FA"/>
                                        <Setter Property="BorderBrush" Value="#1E40AF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#3B82F6" Margin="0,0,7,0"/>
                            <TextBlock Text="Info" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Margin="0,0,6,0" Command="{Binding FilterCommand}" CommandParameter="Warning"
                            Height="32" Padding="14,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLevel}" Value="Warning">
                                        <Setter Property="Foreground" Value="#FCD34D"/>
                                        <Setter Property="BorderBrush" Value="#78350F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#F59E0B" Margin="0,0,7,0"/>
                            <TextBlock Text="Warning" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding FilterCommand}" CommandParameter="Error"
                            Height="32" Padding="14,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLevel}" Value="Error">
                                        <Setter Property="Foreground" Value="#FCA5A5"/>
                                        <Setter Property="BorderBrush" Value="#7F1D1D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#EF4444" Margin="0,0,7,0"/>
                            <TextBlock Text="Error" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <!-- Stats -->
                    <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}">
                            <Run Text="{Binding TotalCount}" Foreground="{StaticResource SubTextBrush}" FontWeight="SemiBold"/>
                            <Run Text=" entries"/>
                        </TextBlock>
                        <Border Background="#0A0F1A" CornerRadius="4" Padding="8,3" Margin="12,0,0,0">
                            <TextBlock FontSize="10">
                                <Run Text="&#xE783;" FontFamily="{StaticResource IconFont}" Foreground="#FCA5A5"/>
                                <Run Text=" "/>
                                <Run Text="{Binding ErrorCount}" Foreground="#FCA5A5" FontWeight="SemiBold"/>
                                <Run Text=" errors" Foreground="{StaticResource MutedTextBrush}"/>
                            </TextBlock>
                        </Border>
                        <Border Background="#0A0F00" CornerRadius="4" Padding="8,3" Margin="6,0,0,0">
                            <TextBlock FontSize="10">
                                <Run Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" Foreground="#FCD34D"/>
                                <Run Text=" "/>
                                <Run Text="{Binding WarningCount}" Foreground="#FCD34D" FontWeight="SemiBold"/>
                                <Run Text=" warnings" Foreground="{StaticResource MutedTextBrush}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logs DataGrid -->
            <DataGrid Grid.Row="1" ItemsSource="{Binding Logs}" Margin="0" RowHeight="42">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                        Width="160" FontFamily="{StaticResource MonoFont}"/>
                    <DataGridTemplateColumn Header="Level" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="7,3" HorizontalAlignment="Left" Margin="6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A1A2E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Background" Value="#2D0808"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Background" Value="#1A1000"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Information">
                                                    <Setter Property="Background" Value="#0A0F1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#FCA5A5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#FCD34D"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Information">
                                                        <Setter Property="Foreground" Value="#93C5FD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn Header="Exception" Binding="{Binding Exception}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
