<Page x:Class="OpenSourceHub.UI.Views.Pages.AiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="AI Insights">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization AI.Title}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="AI-powered repository analysis with OpenAI or Ollama"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Height="44" FontSize="13" Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding LoadRepositoryCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadRepositoryCommand}" Height="44" Padding="20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Load Repository" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Loading -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,100">
                    <controls:LoadingSpinnerControl Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Loading repository..." Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"
                            HorizontalAlignment="Center" Margin="0,80">
                    <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                               FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                    <TextBlock Text="Load a repository to get AI insights" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Get summaries, adoption recommendations, improvement suggestions and answers"
                               Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"
                               FontSize="13" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"/>
                </StackPanel>

                <!-- Loaded repository -->
                <StackPanel Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}">

                    <!-- Repo info bar -->
                    <Border CornerRadius="{StaticResource RadiusMD}" Padding="20,14" Margin="0,0,0,20" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1829" Offset="0"/>
                                <GradientStop Color="#0A0A14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#4C1D95" Offset="0"/>
                                <GradientStop Color="#1A1A38" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                           FontSize="16" Foreground="#8B5CF6" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Repository.FullName}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="·" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock FontSize="13" VerticalAlignment="Center">
                                    <Run Text="&#xE735;" FontFamily="{StaticResource IconFont}" Foreground="#FCD34D"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Repository.StargazersCount, Converter={StaticResource NumberToKiloConverter}}" Foreground="{StaticResource SubTextBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Generating indicator -->
                    <Border CornerRadius="{StaticResource RadiusSM}" Padding="16,11" Margin="0,0,0,16"
                            Background="#12090C" BorderThickness="1" BorderBrush="#4C1D95"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <controls:LoadingSpinnerControl Width="16" Height="16" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Localization AI.Generating}" FontSize="13" Foreground="#C4B5FD" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,8,0" Height="42"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding GenerateSummaryCommand}"
                                IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70B;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                           Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Localization AI.Summary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Margin="4,0" Height="42"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding GenerateAdoptionCommand}"
                                IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                           Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Localization AI.Adoption}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Margin="8,0,0,0" Height="42"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding GenerateImprovementsCommand}"
                                IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                           Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Localization AI.Improvements}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Results -->
                    <Border Style="{StaticResource CardStyle}" Padding="22,18" Margin="0,0,0,12"
                            Visibility="{Binding Summary, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70B;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="#60A5FA" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Localization AI.Summary}" Style="{StaticResource SubHeadingStyle}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding CopyTextCommand}" CommandParameter="{Binding Summary}">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding Summary}" FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="22,18" Margin="0,0,0,12"
                            Visibility="{Binding AdoptionRecommendation, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="#34D399" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Localization AI.Adoption}" Style="{StaticResource SubHeadingStyle}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding CopyTextCommand}" CommandParameter="{Binding AdoptionRecommendation}">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding AdoptionRecommendation}" FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="22,18" Margin="0,0,0,20"
                            Visibility="{Binding ImprovementSuggestions, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE90F;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="#F59E0B" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Localization AI.Improvements}" Style="{StaticResource SubHeadingStyle}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding CopyTextCommand}" CommandParameter="{Binding ImprovementSuggestions}">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding ImprovementSuggestions}" FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <!-- Ask AI chat section -->
                    <Border Style="{StaticResource CardStyle}" Padding="22,18">
                        <StackPanel>
                            <TextBlock Text="{loc:Localization AI.Ask}" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                         Text="{Binding UserQuestion, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42" FontSize="12" Margin="0,0,8,0">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding AskQuestionCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding AskQuestionCommand}" Height="42" Padding="18,0"
                                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Ask →" FontSize="13"/>
                                </Button>
                            </Grid>
                            <Border Background="{StaticResource ElevatedBrush}"
                                    CornerRadius="{StaticResource RadiusSM}" Padding="16,14"
                                    Visibility="{Binding QuestionAnswer, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Text="{Binding QuestionAnswer}" FontSize="12"
                                           Foreground="{StaticResource SubTextBrush}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
