<Page x:Class="OpenSourceHub.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Dashboard">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="36,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D0D18" Offset="0"/>
                    <GradientStop Color="#0A0A14" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Your GitHub intelligence overview" FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}" Padding="16,9">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↻" FontSize="15" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Localization Dashboard.Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28">

                <!-- Loading -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,100">
                    <controls:LoadingSpinnerControl Width="44" Height="44"
                                                    HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Loading your GitHub data…" Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- Content -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">

                    <!-- Profile Banner -->
                    <Border Margin="0,0,0,24" CornerRadius="{StaticResource RadiusLG}"
                            Padding="28,22" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0E1C35" Offset="0"/>
                                <GradientStop Color="#0A1020" Offset="0.6"/>
                                <GradientStop Color="#0D0D1E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <controls:AvatarControl Grid.Column="0" Width="70" Height="70"
                                ImageUrl="{Binding User.AvatarUrl}"
                                DisplayName="{Binding User.Name}"
                                ShowOnline="True" Margin="0,0,20,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding User.Name}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding User.Login, StringFormat='@{0}'}"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding User.Bio}" FontSize="12"
                                           Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap"
                                           Visibility="{Binding User.Bio, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="{Binding User.Company, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="&#xE7EF;" FontFamily="{StaticResource IconFont}"
                                               FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding User.Company}" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Followers}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandPrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Localization Dashboard.Followers}"
                                                   FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                                            VerticalAlignment="Stretch" Margin="0,4"/>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Following}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandPrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Localization Dashboard.Following}"
                                                   FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Stats Grid — 4 cards -->
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SubTextBrush}"
                               Margin="0,0,0,14" Text="OVERVIEW"/>
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Repositories -->
                        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="20,18" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A3A6B" Offset="0"/>
                                    <GradientStop Color="#0F1F3D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1829" Offset="0"/>
                                    <GradientStop Color="#0A1020" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Border Width="36" Height="36" CornerRadius="10" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0D47A1" Offset="0"/>
                                                <GradientStop Color="#1565C0" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#xE74C;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalRepositories}"
                                           FontSize="34" FontWeight="Bold" Foreground="White" Margin="0,0,0,2"/>
                                <TextBlock Text="{loc:Localization Dashboard.TotalRepos}"
                                           FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock Text="public repositories" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stars -->
                        <Border Grid.Column="1" Margin="4,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="20,18" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#78350F" Offset="0"/>
                                    <GradientStop Color="#451F08" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1C1008" Offset="0"/>
                                    <GradientStop Color="#140B05" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Border Width="36" Height="36" CornerRadius="10" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#78350F" Offset="0"/>
                                                <GradientStop Color="#B45309" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalStars, Converter={StaticResource NumberToKiloConverter}}"
                                           FontSize="34" FontWeight="Bold" Foreground="#FCD34D" Margin="0,0,0,2"/>
                                <TextBlock Text="{loc:Localization Dashboard.TotalStars}"
                                           FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock Text="total stars earned" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Forks -->
                        <Border Grid.Column="2" Margin="4,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="20,18" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#064E3B" Offset="0"/>
                                    <GradientStop Color="#022C22" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#061612" Offset="0"/>
                                    <GradientStop Color="#040E0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Border Width="36" Height="36" CornerRadius="10" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#064E3B" Offset="0"/>
                                                <GradientStop Color="#059669" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#xE8F2;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalForks, Converter={StaticResource NumberToKiloConverter}}"
                                           FontSize="34" FontWeight="Bold" Foreground="#34D399" Margin="0,0,0,2"/>
                                <TextBlock Text="{loc:Localization Dashboard.TotalForks}"
                                           FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock Text="forks across repos" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Open Issues -->
                        <Border Grid.Column="3" Margin="8,0,0,0" CornerRadius="{StaticResource RadiusMD}"
                                Padding="20,18" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C1D1D" Offset="0"/>
                                    <GradientStop Color="#450A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#170808" Offset="0"/>
                                    <GradientStop Color="#0F0505" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Border Width="36" Height="36" CornerRadius="10" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C1D1D" Offset="0"/>
                                                <GradientStop Color="#DC2626" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding TotalOpenIssues, Converter={StaticResource NumberToKiloConverter}}"
                                           FontSize="34" FontWeight="Bold" Foreground="#FCA5A5" Margin="0,0,0,2"/>
                                <TextBlock Text="{loc:Localization Dashboard.OpenIssues}"
                                           FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock Text="open issues" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Top Repositories + Recent Activity side by side -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Top by Stars -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FCD34D" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{loc:Localization Dashboard.TopRepositories}"
                                               Style="{StaticResource SubHeadingStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="{StaticResource ElevatedBrush}" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="by stars" FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding TopRepositories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{StaticResource BrandPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,6"
                                                               Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Style="{StaticResource TagStyle}" Padding="7,3"
                                                                Visibility="{Binding Language, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Language}" FontSize="10"
                                                                       Foreground="{StaticResource BrandPrimaryBrush}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding UpdatedAt, Converter={StaticResource DateToRelativeConverter}}"
                                                                   FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Column="1" VerticalAlignment="Center"
                                                        Background="#1A1400" CornerRadius="6" Padding="10,5" Margin="8,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="11" Foreground="#FCD34D" Margin="0,0,4,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding StargazersCount, Converter={StaticResource NumberToKiloConverter}}"
                                                                   FontSize="13" FontWeight="SemiBold" Foreground="#FCD34D"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Recently Updated -->
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00BCF2" Offset="0"/>
                                                <GradientStop Color="#0078D4" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="Recent Activity" Style="{StaticResource SubHeadingStyle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="{StaticResource ElevatedBrush}" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="recently updated" FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RecentRepositories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{StaticResource BrandPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0"
                                                               Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0"
                                                        Background="{StaticResource ElevatedBrush}"
                                                        CornerRadius="4" Padding="8,3">
                                                    <TextBlock Text="{Binding UpdatedAt, Converter={StaticResource DateToRelativeConverter}}"
                                                               FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
