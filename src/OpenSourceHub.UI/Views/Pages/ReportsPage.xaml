<Page x:Class="OpenSourceHub.UI.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      xmlns:domain="clr-namespace:OpenSourceHub.Domain.Enums;assembly=OpenSourceHub.Domain"
      Background="{StaticResource BackgroundBrush}" Title="Reports">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">
            <TextBlock Text="{loc:Localization Report.Title}" Style="{StaticResource HeadingStyle}" Margin="0,0,0,24"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Repository" Style="{StaticResource SubHeadingStyle}" FontSize="15" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding RepositoryQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42" FontSize="13" Margin="0,0,8,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding LoadRepositoryCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Load" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding LoadRepositoryCommand}" Height="42" MinWidth="80"/>
                    </Grid>
                    <TextBlock Text="{Binding Repository.FullName}" FontSize="13"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"
                               Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Report Type" Style="{StaticResource SubHeadingStyle}" FontSize="15" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{loc:Localization Report.Repository}" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding }" Margin="0,0,8,0"/>
                        <Button Content="{loc:Localization Report.Security}" Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Report.Format}" Style="{StaticResource SubHeadingStyle}" FontSize="15" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="PDF" IsChecked="True" Foreground="{StaticResource TextBrush}"
                                     FontSize="13" Margin="0,0,24,0"/>
                        <RadioButton Content="Markdown" Foreground="{StaticResource TextBrush}"
                                     FontSize="13" Margin="0,0,24,0"/>
                        <RadioButton Content="HTML" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{loc:Localization Report.OutputPath}" Style="{StaticResource SubHeadingStyle}"
                               FontSize="15" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding OutputPath}" Height="36" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="{loc:Localization Report.Browse}"
                                Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputPathCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Button Content="{loc:Localization Report.Generate}" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding GenerateReportCommand}"
                    IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                    Height="46" FontSize="15" Margin="0,0,0,16"/>

            <StackPanel Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center" Margin="0,8">
                <TextBlock Text="{loc:Localization Report.Generating}" Style="{StaticResource CaptionStyle}" FontSize="14"/>
            </StackPanel>

            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding LastGeneratedFile, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="✅ Report Generated Successfully!" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding LastGeneratedFile}" FontSize="12"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <Button Content="{loc:Localization Report.Open}" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding OpenReportCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
