<Page x:Class="OpenSourceHub.UI.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      xmlns:domain="clr-namespace:OpenSourceHub.Domain.Enums;assembly=OpenSourceHub.Domain"
      Background="{StaticResource BackgroundBrush}" Title="Reports">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <StackPanel>
                <TextBlock Text="{loc:Localization Reports.Title}"
                           FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                <TextBlock Text="Generate professional PDF, Markdown and HTML reports"
                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,28" MaxWidth="700">

                <!-- Repository selection card -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xF13E;" FontFamily="{StaticResource IconFont}"
                                       FontSize="15" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="Repository" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding RepositoryQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Height="42" FontSize="13" Margin="0,0,8,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoadRepositoryCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding LoadRepositoryCommand}" Height="42" Padding="16,0">
                                <StackPanel Orientation="Horizontal">
                                    <controls:LoadingSpinnerControl Width="14" Height="14" Margin="0,0,7,0"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="Load" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Loaded repo indicator -->
                        <Border CornerRadius="{StaticResource RadiusSM}" Padding="12,9" Margin="0,10,0,0"
                                Background="#0A1400" BorderThickness="1" BorderBrush="#1A3A1A"
                                Visibility="{Binding Repository, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                           Foreground="#34D399" FontSize="13" Margin="0,0,9,0"/>
                                <TextBlock Text="{Binding Repository.FullName}" FontSize="13"
                                           Foreground="#34D399" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Report type card -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}"
                                       FontSize="15" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="Report Type" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Command="{Binding SelectTypeCommand}" CommandParameter="Repository"
                                    Height="38" Padding="16,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedReportType}" Value="Repository">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#0078D4" Offset="0"/>
                                                            <GradientStop Color="#0090F5" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Repository Analysis" FontSize="12"/>
                            </Button>
                            <Button Command="{Binding SelectTypeCommand}" CommandParameter="Security"
                                    Height="38" Padding="16,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedReportType}" Value="Security">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#0078D4" Offset="0"/>
                                                            <GradientStop Color="#0090F5" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Security Assessment" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Format selection card -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE7EA;" FontFamily="{StaticResource IconFont}"
                                       FontSize="15" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Localization Report.Format}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="PDF" Margin="0,0,20,0" FontSize="13"
                                         IsChecked="{Binding SelectedFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static domain:ReportFormat.PDF}}"/>
                            <RadioButton Content="Markdown" Margin="0,0,20,0" FontSize="13"
                                         IsChecked="{Binding SelectedFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static domain:ReportFormat.Markdown}}"/>
                            <RadioButton Content="HTML" FontSize="13"
                                         IsChecked="{Binding SelectedFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static domain:ReportFormat.HTML}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output path card -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}"
                                       FontSize="15" Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Localization Report.OutputPath}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding OutputPath}" Height="40" FontSize="12"
                                     Margin="0,0,8,0" FontFamily="{StaticResource MonoFont}"/>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseOutputPathCommand}" Height="40" Padding="14,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="{StaticResource IconFont}"
                                               FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Browse" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Generate button -->
                <Button Style="{StaticResource PrimaryButtonStyle}" Height="50" FontSize="15" FontWeight="SemiBold"
                        Command="{Binding GenerateReportCommand}" Margin="0,0,0,16"
                        IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <controls:LoadingSpinnerControl Width="20" Height="20" Margin="0,0,12,0"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}" FontSize="15"
                                   Margin="0,0,10,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{loc:Localization Report.Generate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                            <Setter Property="Text" Value="{loc:Localization Report.Generating}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- Success result -->
                <Border CornerRadius="{StaticResource RadiusMD}" Padding="20,16" BorderThickness="1"
                        BorderBrush="#1A3A1A" Background="#0A160A"
                        Visibility="{Binding LastGeneratedFile, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                       FontSize="18" Foreground="#34D399" Margin="0,0,12,0"/>
                            <TextBlock Text="Report Generated Successfully!" FontSize="15"
                                       FontWeight="SemiBold" Foreground="#34D399" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LastGeneratedFile}" FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"
                                Command="{Binding OpenReportCommand}" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7AC;" FontFamily="{StaticResource IconFont}"
                                           FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Open Report" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
