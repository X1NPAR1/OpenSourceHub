<Page x:Class="OpenSourceHub.UI.Views.Pages.RepositoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
      xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
      Background="{StaticResource BackgroundBrush}" Title="Repository">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{loc:Localization Nav.Repository}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,3"/>
                    <TextBlock Text="Browse, edit and commit files, create branches, and view pull requests in your repositories"
                               FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Height="40" Margin="0,0,10,0"
                              ItemsSource="{Binding MyRepositories, Mode=OneWay}"
                              SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                              DisplayMemberPath="FullName"
                              ToolTip="Pick one of your repositories"/>
                    <ComboBox Grid.Column="1" Height="40"
                              ItemsSource="{Binding Branches, Mode=OneWay}"
                              SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              ToolTip="Branch"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedRepository, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}">
                <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="56"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           Foreground="{StaticResource MutedTextBrush}" Opacity="0.4"/>
                <TextBlock Text="Select one of your repositories to manage" FontSize="17" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="Requires a token with the 'repo' scope to commit changes"
                           FontSize="12" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Loading -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                        Panel.ZIndex="50">
                <controls:LoadingSpinnerControl Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Main: files + PRs -->
            <Grid Margin="36,20" Visibility="{Binding SelectedRepository, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Files panel -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Files toolbar -->
                        <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Up one folder"
                                            Command="{Binding GoUpCommand}" IsEnabled="{Binding CanGoUp}">
                                        <TextBlock Text="&#xE74A;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                               Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="6,0,6,0"/>
                                    <TextBlock Text="{Binding CurrentPath}" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                               Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="/" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"
                                               Visibility="{Binding CanGoUp, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding NewFileCommand}" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="New file" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Branch create row -->
                        <Border Grid.Row="1" Padding="16,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}" Height="32" FontSize="12"
                                         Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0" FontFamily="{StaticResource MonoFont}"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding CreateBranchCommand}" Padding="12,0" Height="32">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Create branch from current" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- File list -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Files}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="16,9" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="{StaticResource IconFont}" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE8B7;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource BrandAccentBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                                           Cursor="Hand">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                            Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Open / edit"
                                                            Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Delete file"
                                                            Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"
                                                            Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                                                   Foreground="{StaticResource ErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Pull Requests panel -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14"
                                           Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Open Pull Requests" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="No open pull requests" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                           Margin="16,16" HorizontalAlignment="Center"
                                           Visibility="{Binding PullRequests.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding PullRequests}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                                                    Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                        Command="{Binding DataContext.OpenPullRequestCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Number, StringFormat='#{0}'}" FontSize="11"
                                                                   Foreground="{StaticResource BrandPrimaryBrush}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}" FontSize="11"
                                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding HeadBranch}" FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                                       Foreground="{StaticResource SubTextBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ FILE EDITOR OVERLAY ═══ -->
            <Grid Background="#CC000000" Panel.ZIndex="100"
                  Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource RadiusLG}"
                        Width="780" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="24,16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="Edit &amp; Commit" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBox Text="{Binding EditorPath, Mode=TwoWay}" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Style="{StaticResource ModernTextBoxStyle}" Height="30" Margin="0,8,0,0"
                                         IsReadOnly="{Binding IsNewFile, Converter={StaticResource InverseBoolConverter}}"/>
                            </StackPanel>
                        </Border>
                        <TextBox Grid.Row="1" Text="{Binding EditorContent, Mode=TwoWay}"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                                 Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0" Padding="20,14" AcceptsReturn="True" AcceptsTab="True"
                                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"/>
                        <Border Grid.Row="2" Padding="24,16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CommitMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}" Height="38" FontSize="12"
                                         Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel"
                                            Command="{Binding CancelEditorCommand}" Padding="18,9" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveFileCommand}" Padding="18,9">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,7,0"/>
                                            <TextBlock Text="Commit"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
