<Window x:Class="OpenSourceHub.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OpenSourceHub.UI.Controls"
        xmlns:services="clr-namespace:OpenSourceHub.UI.Services"
        Title="OpenSourceHub — Analyze. Discover. Build Better."
        Icon="/Assets/AppIcon.png"
        Width="1380" Height="840"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>
        <Style x:Key="TitleBarBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#252545" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#C42B1C" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bd"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═════════════════════════════════════════
                 CUSTOM TITLE BAR
            ═════════════════════════════════════════ -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#080812" Offset="0"/>
                        <GradientStop Color="#0A0A18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo area in title bar -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0">
                        <controls:AppLogoControl Width="20" Height="20" Margin="0,0,9,0"/>
                        <TextBlock Text="OpenSourceHub" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BrandPrimaryBrush}" CornerRadius="3"
                                Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.8">
                            <TextBlock Text="v1.2.6" FontSize="9" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Current page title -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarBtnStyle}" Content="─"
                                ToolTip="Minimize" Click="MinimizeButton_Click"/>
                        <Button x:Name="MaxButton" Style="{StaticResource TitleBarBtnStyle}"
                                Content="□" ToolTip="Maximize" Click="MaximizeButton_Click"/>
                        <Button Style="{StaticResource CloseBtnStyle}" Content="✕"
                                ToolTip="Close" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═════════════════════════════════════════
                 MAIN LAYOUT
            ═════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─────────────────────────────────────
                     SIDEBAR
                ───────────────────────────────────── -->
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#07070F" Offset="0"/>
                            <GradientStop Color="#0A0A16" Offset="0.5"/>
                            <GradientStop Color="#080812" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User profile area -->
                        <Border Grid.Row="0" Padding="14,16,14,14"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1829" Offset="0"/>
                                    <GradientStop Color="#0A1020" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <controls:AvatarControl Grid.Column="0" Width="38" Height="38"
                                    ImageUrl="{Binding CurrentUser.AvatarUrl}"
                                    DisplayName="{Binding CurrentUser.Name}"
                                    ShowOnline="True" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentUser.Name}" FontSize="12.5"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding CurrentUser.Login, StringFormat='@{0}'}"
                                               FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- Online indicator -->
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="{StaticResource SuccessBrush}" VerticalAlignment="Top"
                                         HorizontalAlignment="Right" Margin="0,2,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#10B981" Opacity="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <!-- Navigation -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="MAIN" Style="{StaticResource SectionLabelStyle}"/>

                                <Button x:Name="DashboardBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Dashboard">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE80F;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Dashboard]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="AnalyzeBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Analyze">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xF13E;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Analyze]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="TrendingBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Trending">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C2;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Trending]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="CompareBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Compare">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7A8;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Compare]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="INSIGHTS" Style="{StaticResource SectionLabelStyle}"/>

                                <Button x:Name="OrgBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Organizations">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xF136;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Organizations]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="SecurityBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Security">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Security]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="AiBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="AI">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEBE8;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.AI]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="MANAGE" Style="{StaticResource SectionLabelStyle}"/>

                                <Button x:Name="FavoritesBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Favorites">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE734;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Favorites]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="ReportsBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Reports">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Reports]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="LogsBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Logs">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xF000;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Logs]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="SettingsBtn" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Settings">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Loc[Nav.Settings]}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Bottom: sign out + branding -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="0,1,0,0" Padding="8,8">
                            <StackPanel>
                                <Button Style="{StaticResource NavItemStyle}"
                                        Command="{Binding SignOutCommand}"
                                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xF3B1;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"
                                                   Foreground="{StaticResource ErrorBrush}"/>
                                        <TextBlock Text="{Binding Loc[Auth.SignOut]}"
                                                   VerticalAlignment="Center" Foreground="{StaticResource ErrorBrush}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Brand footer -->
                                <Border Margin="8,6,8,2" Padding="10,7" CornerRadius="6">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#0A1830" Offset="0"/>
                                            <GradientStop Color="#0A1020" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <controls:AppLogoControl Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center" Opacity="0.7">
                                            <Run Text="XinPari Software"/>
                                            <Run Text=" · " Foreground="{StaticResource BorderBrush}"/>
                                            <Run Text="MIT"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─────────────────────────────────────
                     PAGE AREA
                ───────────────────────────────────── -->
                <Grid Grid.Column="1">
                    <Border x:Name="PageContainer" Background="{StaticResource BackgroundBrush}">
                        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
                               Background="Transparent"/>
                    </Border>

                    <!-- Notification overlay (top-right) -->
                    <StackPanel x:Name="NotifContainer" VerticalAlignment="Top"
                                HorizontalAlignment="Right" Margin="0,16,16,0"
                                Width="360" Panel.ZIndex="100"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
