<Window x:Class="OpenSourceHub.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OpenSourceHub.Localization;assembly=OpenSourceHub.Localization"
        xmlns:services="clr-namespace:OpenSourceHub.UI.Services"
        Title="OpenSourceHub"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3D3D54"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#00BCF2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="OpenSourceHub" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowControlButton}" Content="─"
                                Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource WindowControlButton}" Content="□"
                                Click="MaximizeButton_Click" x:Name="MaxButton"/>
                        <Button Style="{StaticResource CloseButton}" Content="✕"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User Profile -->
                        <Border Grid.Row="0" Padding="16,20,16,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0"
                                            Background="{StaticResource BrandPrimaryBrush}">
                                        <TextBlock Text="{Binding CurrentUser.Login, Converter={StaticResource InitialConverter}}"
                                                   FontSize="16" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CurrentUser.Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                        <TextBlock Text="{Binding CurrentUser.Login}" FontSize="11"
                                                   Foreground="{StaticResource SubTextBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Navigation -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="0,8">
                                <TextBlock Text="MAIN" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource SubTextBrush}" Margin="24,8,0,4"
                                           Opacity="0.6"/>
                                <Button x:Name="DashboardBtn" Content="📊  Dashboard" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Dashboard"/>
                                <Button x:Name="AnalyzeBtn" Content="🔍  Analyze" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Analyze"/>
                                <Button x:Name="TrendingBtn" Content="🔥  Trending" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Trending"/>
                                <Button x:Name="CompareBtn" Content="⚖️  Compare" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Compare"/>

                                <TextBlock Text="INSIGHTS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource SubTextBrush}" Margin="24,12,0,4"
                                           Opacity="0.6"/>
                                <Button x:Name="OrgBtn" Content="🏢  Organizations" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Organizations"/>
                                <Button x:Name="SecurityBtn" Content="🛡️  Security" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Security"/>
                                <Button x:Name="AiBtn" Content="🤖  AI Insights" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="AI"/>

                                <TextBlock Text="MANAGE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource SubTextBrush}" Margin="24,12,0,4"
                                           Opacity="0.6"/>
                                <Button x:Name="FavoritesBtn" Content="⭐  Favorites" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Favorites"/>
                                <Button x:Name="ReportsBtn" Content="📄  Reports" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Reports"/>
                                <Button x:Name="LogsBtn" Content="📋  Logs" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Logs"/>
                                <Button x:Name="SettingsBtn" Content="⚙️  Settings" Style="{StaticResource NavItemStyle}"
                                        Click="NavButton_Click" Tag="Settings"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Sign Out -->
                        <Border Grid.Row="2" Padding="8,8"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Content="↩  Sign Out" Style="{StaticResource NavItemStyle}"
                                    Command="{Binding SignOutCommand}"
                                    Foreground="{StaticResource ErrorBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <Grid Grid.Column="1">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

                    <!-- Notification Overlay -->
                    <ItemsControl x:Name="NotificationPanel" VerticalAlignment="Top" HorizontalAlignment="Right"
                                  Margin="0,16,16,0" Width="320"
                                  ItemsSource="{Binding Source={x:Static services:NotificationService.Instance}, Path=Notifications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Margin="0,0,0,8" Padding="16,12">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2D2D42" Opacity="0.97"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Type, Converter={StaticResource NotifIconConverter}}"
                                                   FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding Message}" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       TextWrapping="Wrap" MaxWidth="240"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
