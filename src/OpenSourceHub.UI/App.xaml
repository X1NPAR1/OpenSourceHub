<Application x:Class="OpenSourceHub.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OpenSourceHub.UI.Converters"
             xmlns:services="clr-namespace:OpenSourceHub.UI.Services">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converter Instances -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:NumberToKiloConverter x:Key="NumberToKiloConverter"/>
            <conv:HealthScoreToColorConverter x:Key="HealthScoreToColorConverter"/>
            <conv:HealthLevelToStringConverter x:Key="HealthLevelToStringConverter"/>
            <conv:SecurityRiskToColorConverter x:Key="SecurityRiskToColorConverter"/>
            <conv:DateToRelativeConverter x:Key="DateToRelativeConverter"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:ListCountToVisibilityConverter x:Key="ListCountToVisibilityConverter"/>
            <conv:BytesToMbConverter x:Key="BytesToMbConverter"/>
            <conv:BoolCheckConverter x:Key="BoolCheckConverter"/>
            <conv:FavoriteLabelConverter x:Key="FavoriteLabelConverter"/>
            <conv:InitialConverter x:Key="InitialConverter"/>
            <conv:NotifIconConverter x:Key="NotifIconConverter"/>
            <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
