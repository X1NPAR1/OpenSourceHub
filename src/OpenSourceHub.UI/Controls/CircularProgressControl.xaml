<UserControl x:Class="OpenSourceHub.UI.Controls.CircularProgressControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="90" Height="90">

    <Grid Width="90" Height="90">
        <!-- Background ring -->
        <Ellipse Width="82" Height="82" StrokeThickness="7"
                 Stroke="#252545" Fill="Transparent"/>

        <!-- Progress arc via Path set from code-behind -->
        <Path x:Name="ArcPath" StrokeThickness="7" Fill="Transparent"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round">
            <Path.Stroke>
                <LinearGradientBrush x:Name="ArcGradient" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="GradStop1" Color="#0078D4" Offset="0"/>
                    <GradientStop x:Name="GradStop2" Color="#00BCF2" Offset="1"/>
                </LinearGradientBrush>
            </Path.Stroke>
        </Path>

        <!-- Center content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0">
            <TextBlock x:Name="ValueText" Text="0" FontSize="22" FontWeight="Bold"
                       Foreground="#E2E8F0" HorizontalAlignment="Center"/>
            <TextBlock Text="/100" FontSize="10" Foreground="#64748B"
                       HorizontalAlignment="Center" Margin="0,-2,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
