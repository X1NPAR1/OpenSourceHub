<UserControl x:Class="OpenSourceHub.UI.Controls.AppLogoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="36" Height="36"
             RenderTransformOrigin="0.5,0.5">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="PrimaryGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0090F5" Offset="0"/>
            <GradientStop Color="#0060C8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00BCF2" Offset="0"/>
            <GradientStop Color="#0078D4" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="NodeGlow" BlurRadius="6" ShadowDepth="0" Color="#0090F5" Opacity="0.9"/>
        <DropShadowEffect x:Key="HubGlow" BlurRadius="10" ShadowDepth="0" Color="#0078D4" Opacity="1"/>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <!-- Orbit ring rotation -->
                    <DoubleAnimation
                        Storyboard.TargetName="OrbitCanvas"
                        Storyboard.TargetProperty="(Canvas.RenderTransform).(RotateTransform.Angle)"
                        From="0" To="360" Duration="0:0:4"
                        RepeatBehavior="Forever"/>
                    <!-- Hub pulse -->
                    <DoubleAnimation
                        Storyboard.TargetName="HubEllipse"
                        Storyboard.TargetProperty="Opacity"
                        From="0.85" To="1" Duration="0:0:1.8"
                        AutoReverse="True" RepeatBehavior="Forever"/>
                    <!-- Outer hex pulse -->
                    <DoubleAnimation
                        Storyboard.TargetName="OuterHex"
                        Storyboard.TargetProperty="Opacity"
                        From="0.6" To="0.9" Duration="0:0:2.4"
                        AutoReverse="True" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Canvas Width="36" Height="36" ClipToBounds="False">

        <!-- Background glow halo -->
        <Ellipse Canvas.Left="-2" Canvas.Top="-2" Width="40" Height="40" Opacity="0.12">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0078D4" Offset="0.2"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Outer hexagon — filled -->
        <Path x:Name="OuterHex" Fill="{StaticResource PrimaryGrad}" Opacity="0.75">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="18,2" IsClosed="True">
                        <LineSegment Point="32,10"/>
                        <LineSegment Point="32,26"/>
                        <LineSegment Point="18,34"/>
                        <LineSegment Point="4,26"/>
                        <LineSegment Point="4,10"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>

        <!-- Outer hexagon — stroke -->
        <Path Stroke="{StaticResource AccentGrad}" StrokeThickness="1.2" Fill="Transparent">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="18,2" IsClosed="True">
                        <LineSegment Point="32,10"/>
                        <LineSegment Point="32,26"/>
                        <LineSegment Point="18,34"/>
                        <LineSegment Point="4,26"/>
                        <LineSegment Point="4,10"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>

        <!-- Inner hexagon (smaller) -->
        <Path Stroke="{StaticResource AccentGrad}" StrokeThickness="0.8"
              Fill="Transparent" Opacity="0.4">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="18,8.5" IsClosed="True">
                        <LineSegment Point="26,12.75"/>
                        <LineSegment Point="26,23.25"/>
                        <LineSegment Point="18,27.5"/>
                        <LineSegment Point="10,23.25"/>
                        <LineSegment Point="10,12.75"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>

        <!-- Spoke lines from center to vertices -->
        <Line X1="18" Y1="18" X2="18" Y2="3.5" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>
        <Line X1="18" Y1="18" X2="30.5" Y2="11" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>
        <Line X1="18" Y1="18" X2="30.5" Y2="25" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>
        <Line X1="18" Y1="18" X2="18" Y2="32.5" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>
        <Line X1="18" Y1="18" X2="5.5" Y2="25" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>
        <Line X1="18" Y1="18" X2="5.5" Y2="11" Stroke="{StaticResource AccentGrad}"
              StrokeThickness="0.9" Opacity="0.55"/>

        <!-- Rotating orbit Canvas -->
        <Canvas x:Name="OrbitCanvas" Width="36" Height="36"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <RotateTransform CenterX="18" CenterY="18" Angle="0"/>
            </Canvas.RenderTransform>
            <!-- Dashed orbit ring -->
            <Ellipse Canvas.Left="4" Canvas.Top="4" Width="28" Height="28"
                     StrokeDashArray="2.5 2" StrokeThickness="0.9"
                     Stroke="{StaticResource AccentGrad}" Fill="Transparent" Opacity="0.35"/>
            <!-- Bright node on ring -->
            <Ellipse Canvas.Left="15.5" Canvas.Top="2.5" Width="5" Height="5"
                     Fill="#00BCF2" Opacity="0.95">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="#00BCF2" Opacity="1"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- Vertex nodes (6 corners) -->
        <Ellipse Canvas.Left="15.5" Canvas.Top="0.5" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>
        <Ellipse Canvas.Left="28.5" Canvas.Top="8" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>
        <Ellipse Canvas.Left="28.5" Canvas.Top="23" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>
        <Ellipse Canvas.Left="15.5" Canvas.Top="30.5" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>
        <Ellipse Canvas.Left="2.5" Canvas.Top="23" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>
        <Ellipse Canvas.Left="2.5" Canvas.Top="8" Width="5" Height="5"
                 Fill="{StaticResource AccentGrad}" Effect="{StaticResource NodeGlow}"/>

        <!-- Center hub -->
        <Ellipse x:Name="HubEllipse"
                 Canvas.Left="11" Canvas.Top="11" Width="14" Height="14"
                 Fill="{StaticResource PrimaryGrad}" Effect="{StaticResource HubGlow}"/>
        <!-- Center dot -->
        <Ellipse Canvas.Left="15" Canvas.Top="15" Width="6" Height="6" Fill="White" Opacity="0.9"/>
    </Canvas>
</UserControl>
