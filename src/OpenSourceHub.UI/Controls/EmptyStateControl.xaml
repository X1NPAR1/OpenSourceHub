<UserControl x:Class="OpenSourceHub.UI.Controls.EmptyStateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60">
        <TextBlock x:Name="IconText" Text="📭" FontSize="52"
                   HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.6"/>
        <TextBlock x:Name="TitleText" Text="Nothing here yet"
                   FontSize="16" FontWeight="SemiBold" Foreground="#94A3B8"
                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
        <TextBlock x:Name="SubtitleText" Text="Data will appear here."
                   FontSize="13" Foreground="#64748B"
                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
        <Button x:Name="ActionButton" Visibility="Collapsed" Margin="0,20,0,0"
                HorizontalAlignment="Center" Style="{StaticResource PrimaryButtonStyle}"/>
    </StackPanel>
</UserControl>
